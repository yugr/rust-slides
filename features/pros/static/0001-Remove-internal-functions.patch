index 000000000..ad9c8f300
--- /dev/null
+++ b/llvm/include/llvm/Transforms/IPO/RemoveInternalFunctions.h
@@ -0,0 +1,29 @@
+//===- RemoveInternalFunctions.h - Remove internal funs. --------*- C++ -*-===//
+//
+// Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+// See https://llvm.org/LICENSE.txt for license information.
+// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+//
+//===----------------------------------------------------------------------===//
+//
+// Convert internal functions to global with unique names.
+//
+//===----------------------------------------------------------------------===//
+
+#ifndef LLVM_TRANSFORMS_IPO_REMOVEINTERNALFUNCTIONS_H
+#define LLVM_TRANSFORMS_IPO_REMOVEINTERNALFUNCTIONS_H
+
+#include "llvm/IR/PassManager.h"
+
+namespace llvm {
+
+class Module;
+
+/// Pass to convert @llvm.global.annotations to !annotation metadata.
+struct RemoveInternalFunctionsPass : public PassInfoMixin<RemoveInternalFunctionsPass> {
+  PreservedAnalyses run(Module &M, ModuleAnalysisManager &AM);
+};
+
+} // end namespace llvm
+
+#endif // LLVM_TRANSFORMS_IPO_REMOVEINTERNALFUNCTIONS_H
diff --git a/llvm/lib/Transforms/IPO/RemoveInternalFunctions.cpp b/llvm/lib/Transforms/IPO/RemoveInternalFunctions.cpp
new file mode 100644
index 000000000..efc78facc
--- /dev/null
+++ b/llvm/lib/Transforms/IPO/RemoveInternalFunctions.cpp
@@ -0,0 +1,54 @@
+#include "llvm/Transforms/IPO/RemoveInternalFunctions.h"
+#include "llvm/IR/Function.h"
+#include "llvm/IR/InstIterator.h"
+#include "llvm/IR/Module.h"
+#include "llvm/IR/Analysis.h"
+#include "llvm/Support/Debug.h"
+#include "llvm/Transforms/Utils/ModuleUtils.h"
+
+#include <sstream>
+#include <stdlib.h>
+
+using namespace llvm;
+
+#define DEBUG_TYPE "remove-internal-functions"
+
+PreservedAnalyses RemoveInternalFunctionsPass::run(Module &M,
+                                                   ModuleAnalysisManager &AM) {
+  auto Suffix = M.getSourceFileName();
+  for (auto &C : Suffix) {
+    if (!isalnum(C) && C != '.' && C != '$')
+      C = '.';
+  }
+
+  auto ID = getUniqueModuleId(&M);
+
+  unsigned Statics = 0;
+  unsigned Externs = 0;
+
+  for (auto &F : M) {
+    if (F.isDeclaration())
+      continue;
+    switch (F.getLinkage()) {
+      case GlobalValue::InternalLinkage:
+      case GlobalValue::PrivateLinkage:
+        F.setName(F.getName() + "." + Suffix + "." + ID);
+        ++Statics;
+        break;
+      case GlobalValue::ExternalLinkage:
+        ++Externs;
+        break;
+      default:
+        // Do not consider weak/common symbols from std headers
+        break;
+    }
+  }
+
+  if (getenv("INTERNAL_STATS")) {
+    std::ostringstream OS;
+    OS << "Internal stats: " << Statics << " " << Externs << "\n";
+    errs() << OS.str();
+  }
+
+  return PreservedAnalyses::all();
+}
